# Database
DATABASE_URL="postgresql://postgres:password@localhost:5433/urlshortener"

# Redis (optional — falls back to in-memory cache)
REDIS_URL=

# Server
PORT=3000
NODE_ENV=development

# Session
SESSION_SECRET=change-me-to-a-random-string

# App URL (used for OAuth callback URLs)
APP_URL=http://localhost:3000

# Google OAuth (optional — for local OAuth testing)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional — for local OAuth testing)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
